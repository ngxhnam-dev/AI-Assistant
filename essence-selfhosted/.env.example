# bitHuman Essence Self-Hosted
# Copy this file to .env and fill in your secrets.

# Required
BITHUMAN_API_SECRET=your_api_secret_here
OPENAI_API_KEY=sk-your_openai_key_here

# Model path for terminal scripts only. Docker uses ./models via IMX_MODEL_ROOT.
BITHUMAN_MODEL_PATH=./models/avatar.imx

# Optional behavior
# AGENT_PROMPT="You are a helpful assistant. Respond concisely."
OPENAI_VOICE=coral

# Performance tuning
# Disable local Silero VAD to reduce CPU load. Set to 1 to re-enable it.
BITHUMAN_ENABLE_LOCAL_VAD=0
# Keep no prewarmed idle worker processes on smaller machines.
LIVEKIT_NUM_IDLE_PROCESSES=0

# Networking
# LiveKit advertises this IP in WebRTC candidates. Default 127.0.0.1
# works for localhost and SSH tunnel. For direct public access,
# set NODE_IP to your VPS public IP.
# NODE_IP=203.0.113.1
