# bitHuman Essence Cloud
# Copy this file to .env and fill in your secrets.

# Required
BITHUMAN_API_SECRET=your_api_secret_here
BITHUMAN_AGENT_ID=your_agent_id_here
OPENAI_API_KEY=sk-your_openai_key_here

# Optional behavior
# AGENT_PROMPT="You are a helpful assistant. Respond concisely."
OPENAI_VOICE=coral
LOG_LEVEL=INFO
JOB_MEMORY_WARN_MB=2000
LIVEKIT_NUM_IDLE_PROCESSES=0

# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_WS_URL=wss://your-project.livekit.cloud
LIVEKIT_API_URL=https://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:4202
LIVEKIT_AGENT_NAME=
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
