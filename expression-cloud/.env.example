# bitHuman Expression Cloud
# Copy this file: cp .env.example .env

# ── Required ─────────────────────────────────────────────────
# Get from: www.bithuman.ai > Developer
BITHUMAN_API_SECRET=your_api_secret_here
# For AI conversation (agent.py)
OPENAI_API_KEY=sk-your_openai_key_here

# ── Avatar Face (pick ONE) ───────────────────────────────────
# URL to any face photo:
BITHUMAN_AVATAR_IMAGE=https://tmoobjxlwcwvxvjeppzq.supabase.co/storage/v1/object/public/bithuman/A74NWD9723/image_20251122_000244_372799.jpg
# Or local file (place in ./avatars/ first):
# BITHUMAN_AVATAR_IMAGE=/app/avatars/face.jpg
# Or pre-configured agent ID from bithuman.ai:
# BITHUMAN_AGENT_ID=

# ── Optional ─────────────────────────────────────────────────
# AI persona -- controls how the avatar responds in conversation
# AGENT_PROMPT="You are a helpful assistant. Respond concisely."
# OpenAI TTS voice
OPENAI_VOICE=coral

# ── Networking (usually no changes needed) ───────────────────
# LiveKit advertises this IP in WebRTC candidates. Default 127.0.0.1
# works for localhost and SSH tunnel. For direct public access
# (no SSH tunnel), set to your VPS public IP:
# NODE_IP=203.0.113.1
