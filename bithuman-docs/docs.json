{
  "$schema": "https://mintlify.com/docs.json",
  "name": "bitHuman",
  "theme": "mint",
  "logo": {
    "light": "/images/bithuman-logo.png",
    "dark": "/images/bithuman-logo.png",
    "href": "https://bithuman.ai"
  },
  "favicon": "/images/bitHuman-logo-circle.png",
  "colors": {
    "primary": "#ea5455",
    "light": "#ff7b7c",
    "dark": "#ea5455"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://status.bithuman.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://www.bithuman.ai/#explore"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bithuman-product/bithuman-examples",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/ES953n7bPA",
          "icon": "discord"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "getting-started/quickstart",
              "getting-started/how-it-works",
              "getting-started/use-cases",
              "getting-started/prompts",
              "getting-started/media-guide",
              "getting-started/animal-mode"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/avatar-sessions",
              "deployment/livekit-cloud-plugin",
              "deployment/self-hosted-gpu"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/embed",
              "integrations/webhooks",
              "integrations/events",
              "integrations/flutter"
            ]
          },
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/rate-limits",
              "api-reference/errors"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "api-reference/agent-generation",
              "api-reference/agent-management",
              "api-reference/agent-context"
            ]
          },
          {
            "group": "Assets",
            "pages": [
              "api-reference/file-upload",
              "api-reference/dynamics"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Examples",
            "pages": [
              "examples/overview",
              "examples/audio-clip",
              "examples/microphone",
              "examples/ai-conversation",
              "examples/apple-local",
              "examples/raspberry-pi",
              "examples/self-hosted-plugin"
            ]
          }
        ]
      }
    ]
  },
  "openapi": "api-reference/openapi.yaml",
  "api": {
    "baseUrl": "https://api.bithuman.ai",
    "auth": {
      "method": "key",
      "name": "api-secret"
    }
  },
  "feedback": {
    "thumbRating": true
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.bithuman.ai"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bithuman-product/bithuman-examples",
      "discord": "https://discord.gg/ES953n7bPA"
    }
  }
}
