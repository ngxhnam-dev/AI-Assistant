# bitHuman Web UI (Gradio + FastRTC)
# Copy this file: cp .env.example .env

# ── Required ─────────────────────────────────────────────────
BITHUMAN_MODEL_ROOT=/path/to/models         # Directory containing .imx avatar files
BITHUMAN_API_SECRET=your_api_secret_here    # Get from: www.bithuman.ai > Developer
OPENAI_API_KEY=sk-your_openai_key_here      # For AI conversation (OpenAI Realtime API)
